# ==========================================
# Identidade do Ambiente
# ==========================================
APP_DOMAIN=localhost:5173
APP_PROTOCOL=http
APP_URL=http://localhost:5173

#### Exibir informações sensíveis
DEBUG_CONFIG=false

# Para configuração principal do postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD=""
POSTGRES_URL=localhost
POSTGRES_USER=postgres

# Para ativação do backend
BACKEND_BD=backend
BACKEND_SEN=""
BACKEND_USU=backend

# Ativação do keycloak
KEYCLOAK_BD=keycloak
KEYCLOAK_SEN=""
KEYCLOAK_USU=keycloak

KC_BOOTSTRAP_ADMIN_PASSWORD=""
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_DB_URL=jdbc:postgresql://localhost:5432/keycloak
KC_DB_PASSWORD=keycloak
KC_DB_USERNAME=keycloak
KC_HOSTNAME=http://localhost:8080
KC_ISSUER_URI=http://localhost:8080/realms/corporativo
KC_JWK_SET_URI=http://localhost:8080/realms/corporativo/protocol/openid-connect/certs

# Para ativação do Repositório de Objetos (S3 - Seaweedfs)
S3_ADMIN_ACCESS_KEY=s3_access_key
S3_ADMIN_SECRET_KEY=""
S3_BD=seaweedfs
S3_BUCKET=seagri-fotos
S3_ENDPOINT=http://localhost:8333
S3_SEN=""
S3_USU=seaweedfs
S3_FILER_API_ENDPOINT=http://localhost:8888
TZ=America/Sao_Paulo
WEED_LOG_LEVEL=1

# Credenciais LDAP GDF
LDAP_BIND_DN=ldap@governo.gdfnet.df
LDAP_BIND_PASSWORD=""
#LDAP_URL=ldap://governo.gdfnet.df:3268
LDAP_URL=ldaps://governo.gdfnet.df:3269

# Credenciais para o ambiente de biometria
BIOMETRIA_URL=http://localhost:8000
BIOMETRIA_USUARIO=appbio
CUDA_VISIBLE_DEVICES=-1
DEEPFACE_HOME=/home/appbio
TF_CPP_MIN_LOG_LEVEL=2
TF_ENABLE_ONEDNN_OPTS=0

# Credenciais Google Social Login
GOOGLE_CLIENT_ID="1099489956177-mdqcr5klq0vkd19ppsdc44c7gbd775un.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET=""

# senha do usuário de testes
ABC_SEN=""

#CACHE
REDIS_HOST=localhost
REDIS_PASSWORD=

# ==========================================
# Frontend (React + Vite)
# ==========================================
VITE_API_BASE_URL=http://localhost:8081/api
VITE_KEYCLOAK_URL=http://localhost:8080

# ==========================================
# Configurações de CORS (Origens Permitidas)
# ==========================================
# Para múltiplos endereços em dev ou prod, basta separar por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173,http://frontend-web:5173,https://frontend-web:5173,http://localhost,https://localhost
