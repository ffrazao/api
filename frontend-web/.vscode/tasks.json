{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar Servidor Vite",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready in.*|Local:.*"
        }
      }
    }
  ]
}
